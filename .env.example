# ─────────────────────────────────────────────
# MEMECHAT — ENVIRONMENT VARIABLES (EXAMPLE)
# Copy to .env and fill in real values.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=development
APP_NAME=MemeChat
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PREFIX=api/v1

# ── Frontend (Next.js) ───────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MemeChat

# ── Backend ──────────────────────────────────
PORT=4000
BACKEND_PORT=4000

# ── MongoDB ──────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/memechat
MONGODB_DB_NAME=memechat

# ── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ── OAuth ────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_CALLBACK_URL=http://localhost:4000/api/v1/auth/microsoft/callback

APPLE_CLIENT_ID=your-apple-client-id
APPLE_PRIVATE_KEY_PATH=./certs/apple-auth-key.p8
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id

# ── AWS S3 ───────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=memechat-media
AWS_CLOUDFRONT_URL=https://cdn.memechat.io

# ── Firebase (FCM) ───────────────────────────
FIREBASE_PROJECT_ID=memechat-firebase
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@memechat.iam.gserviceaccount.com

# ── OneSignal ────────────────────────────────
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# ── OpenAI ───────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# ── SMTP (Email) ─────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.your-sendgrid-key
EMAIL_FROM=noreply@memechat.io

# ── Twilio (OTP SMS) ─────────────────────────
TWILIO_ACCOUNT_SID=ACyour-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ── Sentry ───────────────────────────────────
SENTRY_DSN=https://your@sentry.io/project
NEXT_PUBLIC_SENTRY_DSN=https://your@sentry.io/project

# ── Encryption ───────────────────────────────
ENCRYPTION_KEY=32-char-encryption-key-here-xxx
ENCRYPTION_IV=16-char-iv-xxxxx

# ── Rate Limiting ────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── LiveKit (WebRTC SFU) ─────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ── Monitoring ───────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
